# Slack
# Bot Token (xoxb-): write operations only (alerts via chat.postMessage)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# User Token (xoxp-): read operations (conversations.history/replies/info, users.info)
# Has access to all channels/DMs the user can see, including self-DMs
SLACK_USER_TOKEN=xoxp-your-user-token-here
# App-Level Token (xapp-): Socket Mode WebSocket connection
SLACK_APP_TOKEN=xapp-your-app-token-here

# 明示的に監視するチャンネル ID（カンマ区切り）
SLACK_WATCH_CHANNEL_IDS=C00000000,C11111111

# Vegapunk
# Docker on macOS: host.docker.internal / Linux: localhost
VEGAPUNK_GRPC_ENDPOINT=host.docker.internal:6840
VEGAPUNK_AUTH_TOKEN=your-bearer-token-here

# 障害通知（任意）
# SLACK_ALERT_CHANNEL_ID=C99999999

# バッチ・バッファ設定（任意）
# INGEST_BATCH_SIZE=20
# SORT_BUFFER_WINDOW_SECS=5

# ログレベル
RUST_LOG=vegapunk_slack_ingester=info
