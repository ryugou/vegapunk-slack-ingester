# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# 明示的に監視するチャンネル ID（カンマ区切り）
SLACK_WATCH_CHANNEL_IDS=C00000000,C11111111

# Vegapunk
# Docker on macOS: host.docker.internal / Linux: localhost
VEGAPUNK_GRPC_ENDPOINT=host.docker.internal:6840
VEGAPUNK_AUTH_TOKEN=your-bearer-token-here

# 障害通知（任意）
# SLACK_ALERT_CHANNEL_ID=C99999999

# バッチ・バッファ設定（任意）
# INGEST_BATCH_SIZE=20
# SORT_BUFFER_WINDOW_SECS=5

# ログレベル
RUST_LOG=vegapunk_slack_ingester=info
